# Supabase Configuration
# Get these values from your Supabase project dashboard at https://app.supabase.com
# Project Settings > API

# The URL of your Supabase project
VITE_SUPABASE_URL=your_supabase_url_here

# The public/anonymous key for client-side access (safe to expose in frontend)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# The service role key for server-side access (KEEP THIS SECRET - server only)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Backend wallet auth settings
# Long random secret used to sign auth session cookies.
AUTH_SESSION_SECRET=replace_with_a_long_random_secret

# Admin wallet used for admin session role.
ADMIN_WALLET_ADDRESS=4LFaS625N8PjCC1zTyYEdrfvVrEHWTGuhe1dWxRhPcau
